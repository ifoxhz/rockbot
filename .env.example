# Copy to .env and adjust. Values here mirror sensible defaults used in code.

# -----------------------------------------------------------------------------
# rock CLI — default data source: eastmoney | tushare | xueqiu | ivatar
# -----------------------------------------------------------------------------
ROCK_DATA_SOURCE=eastmoney
# Parallel stock downloads (rock command); eastmoney also reads EASTMONEY_BATCH_CONCURRENCY if batch opts omit concurrency
ROCK_DOWNLOAD_CONCURRENCY=3

# -----------------------------------------------------------------------------
# Tushare — required when ROCK_DATA_SOURCE=tushare, and also used by eastmoney
# to supplement daily change_pct / turnover_rate
# -----------------------------------------------------------------------------
TUSHARE_TOKEN=

# -----------------------------------------------------------------------------
# Eastmoney — all optional (defaults match src/services/eastmoneyDailyFlow.js)
# -----------------------------------------------------------------------------
EASTMONEY_FETCH_RETRIES=4
EASTMONEY_CACHE_TTL_MS=120000
EASTMONEY_CACHE_MAX_ENTRIES=400
EASTMONEY_BATCH_CONCURRENCY=3
EASTMONEY_MIN_REQUEST_INTERVAL_MS=1200
EASTMONEY_MAX_REQUEST_INTERVAL_MS=2800
EASTMONEY_MAX_CONNECTIONS=6
EASTMONEY_REQUEST_TIMEOUT_MS=15000
EASTMONEY_KEEPALIVE_TIMEOUT_MS=15000
EASTMONEY_KEEPALIVE_MAX_TIMEOUT_MS=60000
EASTMONEY_IP_HEALTH_COOLDOWN_MS=300000
EASTMONEY_BLOCK_COOLDOWN_MS=180000
EASTMONEY_BLOCK_FAILURE_THRESHOLD=6
EASTMONEY_LIMIT_HIT_COOLDOWN_MS=900000
EASTMONEY_DYNAMIC_DELAY_STEP_MS=1500
EASTMONEY_DYNAMIC_DELAY_MAX_MS=30000
EASTMONEY_REFERER=https://quote.eastmoney.com/
EASTMONEY_UA_STRATEGY=hash
# EASTMONEY_ALLOW_H2=0
# push2his: TCP to these IPs for fund-flow requests only; SNI still push2his.eastmoney.com.
# Daily change_pct / turnover_rate are supplemented by Tushare.
# Omit or leave empty → DNS only.
EASTMONEY_PUSH2HIS_IPS=61.129.129.199,120.79.243.12,117.184.40.129
# EASTMONEY_PUSH2HIS_HOST=push2his.eastmoney.com
# EASTMONEY_CONNECT_TIMEOUT_MS=10000
# EASTMONEY_USER_AGENT=
# EASTMONEY_COOKIE=
# EASTMONEY_DEBUG=1
# Optional proxy envs (used automatically by eastmoney adapter via undici):
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
# Set to 1 to use global fetch instead of undici (no shared HTTP/2 pool)
# EASTMONEY_DISABLE_UNDICI=
# Safer anti-limit profile if Eastmoney starts blocking:
# EASTMONEY_BATCH_CONCURRENCY=1
# EASTMONEY_MIN_REQUEST_INTERVAL_MS=2500
# EASTMONEY_MAX_REQUEST_INTERVAL_MS=6000
# EASTMONEY_ALLOW_H2=0

# -----------------------------------------------------------------------------
# Ivatar — required when ROCK_DATA_SOURCE=ivatar (no safe default URL in repo)
# -----------------------------------------------------------------------------
# IVATAR_DAILY_FLOW_URL=
# IVATAR_TOKEN=
IVATAR_TIMEOUT_MS=12000

# -----------------------------------------------------------------------------
# Xueqiu — required when ROCK_DATA_SOURCE=xueqiu
# -----------------------------------------------------------------------------
# xq_a_token=
# xq_r_token=
# xq_id_token=
# xqat=

# -----------------------------------------------------------------------------
# Email (optional — matched results mail)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=
